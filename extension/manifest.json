{
  "manifest_version": 3,
  "name": "Atomic Clipper",
  "version": "2.0.0",
  "description": "Clip any web content into a local research library. Export to Markdown for NotebookLM, Perplexity, or any LLM.",
  "permissions": ["activeTab", "storage", "scripting"],
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png"
    },
    "default_popup": "popup/popup.html",
    "default_title": "Atomic Clipper — Click to start clipping"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Alt+Shift+S"
      },
      "description": "Open Atomic Clipper popup"
    }
  },
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  }
}
